 Maintenance & Service Logs","height":25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1924264189,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-4724.7872895860291,"angle":0,"y":-15412.723636072995,"width":294.0596923828125},{"isDeleted":false,"locked":false,"strokeColor":"#f08c00","link":null,"roughness":1,"groupIds":[],"index":"bFk","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":188,"roundness":{"type":2},"type":"ellipse","updated":1771591112403,"id":"fDLI-zSw6fNxVw7t6Jqum","x":-4081.89840069714,"seed":1155782195,"boundElements":[],"y":-15372.723636072995,"opacity":100,"height":24,"width":25,"frameId":null,"strokeStyle":"solid","versionNonce":711592231},{"seed":286300115,"strokeStyle":"solid","id":"N-Br_aSKJyYnOY8FxAZSu","strokeWidth":1,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1771591027502,"locked":false,"text":"Fleet Flow","version":160,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"bFl","roundness":null,"containerId":null,"originalText":"Fleet Flow","height":25,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":364808105,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":-4748.7872895860291,"angle":0,"y":-15370.723636072995,"width":101.83990478515625},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"bFm","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":260,"roundness":{"type":3},"type":"rectangle","updated":1771572857457,"id":"Hleuf7eIxT8LftPLZ2dyM","x":-4765.7138649185108,"seed":1769219443,"boundElements":[],"y":-14595.215141629418,"opacity":100,"height":741,"width":728,"frameId":null,"strokeStyle":"solid","versionNonce":839332755},{"seed":894762771,"strokeStyle":"solid","id":"lV97vEmw78-2_Kc7ix1