# ═══════════════════════════════════════════════════════════════
# FleetFlow Frontend Environment Variables (Vite)
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control
# 
# IMPORTANT: All Vite environment variables MUST be prefixed with VITE_
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# FIREBASE CLIENT SDK CONFIGURATION
# ───────────────────────────────────────────────────────────────
# These values are safe to expose in client-side code
# They identify your Firebase project but don't grant access
# Access control is enforced by Firestore Security Rules

# HOW TO GET THESE VALUES:
# 1. Go to https://console.firebase.google.com/
# 2. Select your project (or create a new one)
# 3. Click the gear icon → Project Settings
# 4. Scroll down to "Your apps" section
# 5. If no web app exists, click "Add app" → Web (</>) icon
# 6. Register your app with a nickname (e.g., "FleetFlow Web")
# 7. Copy the firebaseConfig object values below

VITE_FIREBASE_API_KEY=AIzaSyBwvUI61XXmTLWvR0iUzSgXH4leeCS4aQk
VITE_FIREBASE_AUTH_DOMAIN=fleet-6a128.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=fleet-6a128
VITE_FIREBASE_STORAGE_BUCKET=fleet-6a128.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=14302289624
VITE_FIREBASE_APP_ID=1:14302289624:web:53bbc2084d9b5a44ec01ad
VITE_FIREBASE_MEASUREMENT_ID=G-458KN9FCP3

# ───────────────────────────────────────────────────────────────
# BACKEND API CONFIGURATION
# ───────────────────────────────────────────────────────────────

# Backend API base URL
# Development: http://localhost:5000
# Production: https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:5000

# ───────────────────────────────────────────────────────────────
# OPTIONAL: FEATURE FLAGS
# ───────────────────────────────────────────────────────────────

# Enable debug mode (shows console logs)
VITE_DEBUG_MODE=false

# Enable analytics tracking
VITE_ENABLE_ANALYTICS=false

# ═══════════════════════════════════════════════════════════════
# FIREBASE SETUP GUIDE
# ═══════════════════════════════════════════════════════════════
#
# STEP 1: CREATE FIREBASE PROJECT
# --------------------------------
# 1. Go to https://console.firebase.google.com/
# 2. Click "Add project" or "Create a project"
# 3. Enter project name: "FleetFlow" (or your choice)
# 4. Enable/disable Google Analytics (optional)
# 5. Click "Create project"
#
# STEP 2: ENABLE FIRESTORE DATABASE
# ----------------------------------
# 1. In Firebase Console, click "Firestore Database" in left sidebar
# 2. Click "Create database"
# 3. Choose "Start in test mode" (for development)
#    OR "Start in production mode" (requires security rules)
# 4. Select a Cloud Firestore location (choose closest to your users)
# 5. Click "Enable"
#
# STEP 3: GET WEB APP CREDENTIALS
# --------------------------------
# 1. In Firebase Console, click the gear icon → Project Settings
# 2. Scroll to "Your apps" section
# 3. Click the Web icon (</>) to add a web app
# 4. Register app with nickname: "FleetFlow Web"
# 5. Copy the firebaseConfig values to this .env file
#
# STEP 4: SET UP FIRESTORE SECURITY RULES (IMPORTANT!)
# -----------------------------------------------------
# 1. Go to Firestore Database → Rules tab
# 2. Replace default rules with production-ready rules
# 3. See backend/.env.example for recommended security rules
#
# STEP 5: CONFIGURE AUTHENTICATION (OPTIONAL)
# --------------------------------------------
# If you want to use Firebase Authentication instead of custom backend auth:
# 1. In Firebase Console, click "Authentication" in left sidebar
# 2. Click "Get started"
# 3. Enable "Email/Password" sign-in method
# 4. Update frontend code to use Firebase Auth SDK
#
# ═══════════════════════════════════════════════════════════════
# SETUP CHECKLIST
# ═══════════════════════════════════════════════════════════════
# [ ] Copy this file to .env
# [ ] Create Firebase project
# [ ] Enable Firestore Database
# [ ] Get Firebase web app credentials
# [ ] Update all VITE_FIREBASE_* values above
# [ ] Set up Firestore Security Rules
# [ ] Add .env to .gitignore (already done)
# [ ] Run: npm install
# [ ] Run: npm run dev
# [ ] Test login at http://localhost:5173
# ═══════════════════════════════════════════════════════════════
